# ============================================================
# ThreatLens AI - Environment Configuration
# ============================================================
# Copy this file to .env and update values before deployment

# --- Database ---
POSTGRES_USER=threatlens
POSTGRES_PASSWORD=threatlens_secure_pass_change_me
POSTGRES_DB=threatlens_db

# --- Redis ---
REDIS_PASSWORD=redis_secure_pass_change_me

# --- Security ---
SECRET_KEY=super_secret_key_change_in_production_must_be_32_chars_minimum
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Application ---
ENVIRONMENT=production
LOG_LEVEL=INFO
MAX_FILE_SIZE_MB=50

# --- CORS ---
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:3000

# --- Frontend ---
REACT_APP_API_URL=/api/v1
